# HubSpot — Private App Access Token
# Create at: HubSpot > Settings > Integrations > Private Apps
HUBSPOT_ACCESS_TOKEN=your_hubspot_private_app_token_here

# HubSpot Hub ID (for ticket links in the UI)
# Find it in HubSpot URL: app.hubspot.com/contacts/{THIS_NUMBER}/...
NEXT_PUBLIC_HUBSPOT_HUB_ID=your_hub_id_here

# AI Provider: "claude" (default) or "gemini"
AI_PROVIDER=claude

# Anthropic API Key (Claude) — required when AI_PROVIDER=claude
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google AI API Key (Gemini) — required when AI_PROVIDER=gemini
# Get one at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_ai_api_key_here

# Authentication
# Required: random secret for JWT signing (generate with: openssl rand -base64 32)
AUTH_SECRET=your_random_secret_here
# Master account credentials (seeded on first run)
MASTER_USERNAME=admin
MASTER_PASSWORD=changeme

# SQLite database path (relative to project root)
DATABASE_PATH=./data/kb.db

# How many accumulated new Q&A pairs trigger an automatic re-clustering
RECLUSTER_THRESHOLD=20

# Ticket limit per sync (0 = no limit)
SYNC_LIMIT=0

# Gmail OAuth2 (for email draft generation)
# Create at: Google Cloud Console > APIs & Services > Credentials > OAuth 2.0 Client IDs
# Enable the Gmail API and set scope: https://www.googleapis.com/auth/gmail.compose
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/gmail/callback

# Encryption key for Gmail tokens at rest (generate with: openssl rand -hex 32)
GMAIL_TOKEN_ENCRYPTION_KEY=
